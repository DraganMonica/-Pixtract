@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Pixtract — Extragere caracteristici produse";
}

<!-- HERO -->
<section class="hero-section">
    <div class="container py-5">
        <div class="row align-items-center g-5 py-5">
            <div class="col-lg-6">
                <span class="badge hero-badge mb-3">AI-Powered</span>
                <h1 class="hero-title">
                    Extrage automat caracteristici din imagini  <span class="hero-gradient-text"> in cateva secunde</span>
                </h1>
                <p class="hero-subtitle">
                    Incarci o imagine de produs, primesti automat caracteristicile specifice categoriei — gata de exportat in Excel.
                </p>
                
            </div>
            <div class="col-lg-6">
                <div class="hero-card">
                    <div class="hero-card-header">
                        <div class="d-flex align-items-center gap-2">
                            <div class="hero-dot red"></div>
                            <div class="hero-dot yellow"></div>
                            <div class="hero-dot green"></div>
                            <span class="text-white-50 small ms-2">Extragere caracteristici</span>
                        </div>
                    </div>
                    <div class="hero-card-body">
                        <div class="d-flex gap-3 align-items-start">
                            <div class="hero-img-placeholder">
                                <i class="bi bi-image text-white-50 fs-3"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="hero-attr-row">
                                    <span class="hero-attr-label">Categorie</span>
                                    <span class="hero-attr-value">Tricouri dama</span>
                                </div>
                                <div class="hero-attr-row">
                                    <span class="hero-attr-label">Culoare</span>
                                    <span class="hero-attr-value">Alb</span>
                                </div>
                               
                                <div class="hero-attr-row">
                                    <span class="hero-attr-label">Tip maneca</span>
                                    <span class="hero-attr-value">Scurta</span>
                                </div>
                                <div class="hero-attr-row">
                                    <span class="hero-attr-label">Decolteu</span>
                                    <span class="hero-attr-value">Rotund</span>
                                </div>
                                <div class="hero-attr-row">
                                    <span class="hero-attr-label">Imprimeu</span>
                                    <span class="hero-attr-value">Desene animate</span>
                                </div>
                            </div>
                        </div>
                        <div class="mt-3 text-end">
                            <span class="badge bg-success">
                                <i class="bi bi-check-circle me-1"></i>Extras cu succes
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>



<!-- FEATURES -->
<section class="features-section py-6" id="features">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">De ce Pixtract?</h2>
            <p class="section-subtitle">Tot ce ai nevoie pentru a automatiza descrierile de produse</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-magic"></i>
                    </div>
                    <h5 class="feature-title">AI avansat</h5>
                    <p class="feature-text">Model de viziune antrenat special pe produse de fashion si retail.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-images"></i>
                    </div>
                    <h5 class="feature-title">Imagini multiple</h5>
                    <p class="feature-text">Proceseaza pana la 10 imagini intr-un singur request (plan Ultra).</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-file-earmark-excel"></i>
                    </div>
                    <h5 class="feature-title">Export Excel</h5>
                    <p class="feature-text">Descarca rezultatele instant in format Excel gata de import.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <h5 class="feature-title">Istoric complet</h5>
                    <p class="feature-text">Acces la toate extractiile anterioare, oricand ai nevoie.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- STEPS -->
<section class="steps-section py-6">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Cum functioneaza?</h2>
            <p class="section-subtitle">Trei pasi simpli pana la atributele produsului</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h5 class="step-title">Incarci imaginea/imaginile in functie de planul selectat</h5>
                    <p class="step-text">Drag & drop sau selecteaza una sau mai multe imagini ale produsului.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h5 class="step-title">Modelul AI analizeaza</h5>
                    <p class="step-text">Detecteaza automat caracteristici specifice categoriei din care face parte produsul.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h5 class="step-title">Exporti rezultatul</h5>
                    <p class="step-text">Descarci fisierul Excel cu toate atributele, gata de utilizat.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<!-- PLANS PREVIEW -->
<section class="steps-section py-6" id="pricing">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Planuri simple, fara surprize</h2>
            <p class="section-subtitle">Incepe gratuit, upgradeaza oricand</p>
        </div>
        <div class="row justify-content-center g-4">
            <div class="col-md-4">
                <div class="plan-card">
                    <div class="plan-name">Free</div>
                    <div class="plan-price">
                        <span class="plan-amount">$0</span>
                    </div>
                    <ul class="plan-features">
                        <li><i class="bi bi-check-circle-fill text-success"></i><span>10 imagini / zi</span></li>
                        <li><i class="bi bi-check-circle-fill text-success"></i><span>1 imagine / request</span></li>
                        <li><i class="bi bi-x-circle-fill text-danger"></i><span class="text-muted">Export doar rezultat curent</span></li>
                    </ul>
                </div>
            </div>
            <div class="col-md-4">
                <div class="plan-card popular">
                    <div class="popular-badge"><i class="bi bi-star-fill me-1"></i>POPULAR</div>
                    <div class="plan-name">Pro</div>
                    <div class="plan-price">
                        <span class="plan-amount">$9.99</span>
                        <span class="plan-period">/luna</span>
                    </div>
                    <ul class="plan-features">
                        <li><i class="bi bi-check-circle-fill text-success"></i><span>50 imagini / zi</span></li>
                        <li><i class="bi bi-check-circle-fill text-success"></i><span>5 imagini / request</span></li>
                        <li><i class="bi bi-check-circle-fill text-success"></i><span>Export istoric complet</span></li>
                    </ul>
                </div>
            </div>
            <div class="col-md-4">
                <div class="plan-card">
                    <div class="plan-name">Ultra</div>
                    <div class="plan-price">
                        <span class="plan-amount">$24.99</span>
                        <span class="plan-period">/luna</span>
                    </div>
                    <ul class="plan-features">
                        <li><i class="bi bi-check-circle-fill text-success"></i><span>200 imagini / zi</span></li>
                        <li><i class="bi bi-check-circle-fill text-success"></i><span>10 imagini / request</span></li>
                        <li><i class="bi bi-check-circle-fill text-success"></i><span>Export istoric complet</span></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="cta-section py-6">
    <div class="container">
        <div class="cta-card text-center">
            <h2 class="cta-title">Gata sa incepi?</h2>
            <p class="cta-subtitle">Creeaza un cont gratuit si extrage primele caracteristici in mai putin de un minut.</p>
            <a asp-controller="Account" asp-action="Register"
               class="btn btn-light btn-lg px-5 py-3 fw-semibold mt-3">
                <i class="bi bi-rocket-takeoff me-2"></i>Incearca gratuit
            </a>
        </div>
    </div>
</section>
